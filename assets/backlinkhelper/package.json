{
  "name": "backliner-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal executable backbone for shared-CDP backlink submission workflows.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm build && node --test dist/**/*.test.js",
    "start-browser": "node dist/cli/index.js start-browser",
    "preflight": "node dist/cli/index.js preflight",
    "enqueue-site": "node dist/cli/index.js enqueue-site",
    "guarded-drain-status": "node dist/cli/index.js guarded-drain-status",
    "mailbox-triage": "node dist/cli/index.js mailbox-triage",
    "follow-up-tick": "node dist/cli/index.js follow-up-tick",
    "missing-input-preflight": "node dist/cli/index.js missing-input-preflight",
    "claim-next-task": "node dist/cli/index.js claim-next-task",
    "task-prepare": "node dist/cli/index.js task-prepare",
    "task-record-agent-trace": "node dist/cli/index.js task-record-agent-trace",
    "task-finalize": "node dist/cli/index.js task-finalize",
    "run-next": "node dist/cli/index.js run-next",
    "repartition-retry-decisions": "node dist/cli/index.js repartition-retry-decisions",
    "drain-worker": "node scripts/drain-worker.mjs",
    "sync-skills": "node scripts/sync-skills.mjs",
    "validate-skills": "node scripts/validate-skills.mjs",
    "diff-skills": "node scripts/diff-skills.mjs"
  },
  "dependencies": {
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "typescript": "^5.8.3"
  }
}
